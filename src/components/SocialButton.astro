<style>
  .social-btn {
    width: 48px;
    height: 48px;
    background: var(--bg-page);
    border: 1px solid var(--border-default);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--content-primary);
    flex-shrink: 0;
    transition: opacity 0.15s, transform 0.15s;
  }
  .social-btn:hover {
    opacity: 0.6;
    transform: translateY(-2px);
  }
</style>
