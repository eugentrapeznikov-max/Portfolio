---
import Tag from './Tag.astro';

interface Props {
  caseStudy: 'ITMO' | 'RedCross' | 'WearSun';
}
const { caseStudy } = Astro.props;

const content = {
  ITMO: {
    title: 'Guest Lecturer at ITMO University',
    description: 'Invited to teach an original UX/UI design course at ITMO University — a challenging and deeply rewarding experience beyond product design.',
    date: 'Sep 2025 — Feb 2026',
    image: '/initiatives/itmo.png',
    pad: 40,
  },
  WearSun: {
    title: 'WearSun: Custom Insoles Experience',
    description: "Designed the store, scanning app, and purchase funnel for a startup producing unique insoles tailored to each customer's feet.",
    date: 'Mar 2026 — Apr 2026',
    image: '/initiatives/wearsun.png',
    pad: 64,
  },
  RedCross: {
    title: 'Donation Platform for the Russian Red Cross',
    description: 'Designed a fundraising platform that enables anyone to launch a charitable campaign and support people in need.',
    date: 'Jan 2026 — Mar 2026',
    image: '/initiatives/redcross.png',
    pad: 64,
  },
};

const c = content[caseStudy];
---
<div class="init-card">
  <div class="init-card__image" style={`padding-left:${c.pad}px;padding-right:${c.pad}px`}>
    <img src={c.image} alt={c.title} loading="lazy" />
  </div>
  <div class="init-card__divider"></div>
  <div class="init-card__content">
    <h3 class="init-card__title">{c.title}</h3>
    <p class="init-card__desc">{c.description}</p>
    <Tag label="Case Study Coming Soon" color="#6b5fd4" />
    <span class="init-card__date">{c.date}</span>
  </div>
</div>

<style>
  .init-card {
    background: var(--bg-page);
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }
  .init-card__image {
    height: 190px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 52px;
    padding-bottom: 52px;
    background: var(--bg-page);
  }
  .init-card__image img {
    max-width: 100%;
    max-height: 100%;
    width: 100%;
    height: auto;
    min-width: 0;
    object-fit: contain;
    display: block;
  }
  .init-card__divider {
    height: 1px;
    width: 100%;
    flex-shrink: 0;
    background: var(--border-default);
  }
  .init-card__content {
    padding: 32px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }
  .init-card__title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: var(--weight-medium);
    font-size: var(--text-3xl);
    line-height: 32px;
    color: var(--content-primary);
  }
  .init-card__desc {
    font-size: var(--text-base);
    line-height: 20px;
    color: var(--content-secondary);
  }
  .init-card__date {
    font-size: var(--text-sm);
    line-height: 16px;
    color: var(--content-secondary);
  }
</style>
