---
import Tag from './Tag.astro';

interface Props {
  caseStudy: 'ITMO' | 'RedCross' | 'WearSun';
}
const { caseStudy } = Astro.props;

const content = {
  ITMO: {
    title: 'Guest Lecturer at ITMO University',
    description: 'Invited to teach an original UX/UI design course at ITMO University — a challenging and deeply rewarding experience beyond product design.',
    date: 'Sep 2025 — Feb 2026',
    image: '/initiatives/ITMOLogo.png',
  },
  RedCross: {
    title: 'Donation Platform for the Russian Red Cross',
    description: 'Designed a fundraising platform that enables anyone to launch a charitable campaign and support people in need.',
    date: 'Jan 2026 — Mar 2026',
    image: '/initiatives/RedCross.svg',
  },
  WearSun: {
    title: 'WearSun: Custom Insoles Experience',
    description: "Designed the store, scanning app, and purchase funnel for a startup producing unique insoles tailored to each customer's feet.",
    date: 'Mar 2026 — Apr 2026',
    image: '/initiatives/WearSun.svg',
  },
};

const c = content[caseStudy];
---
<div class="init-card">
  <div class="init-card__image">
    <img src={c.image} alt={c.title} loading="lazy" />
  </div>
  <div class="init-card__content">
    <h3 class="init-card__title">{c.title}</h3>
    <p class="init-card__desc">{c.description}</p>
    <div class="init-card__bottom">
      <Tag label="Case Study Coming Soon" color="#6b5fd4" />
      <span class="init-card__date">{c.date}</span>
    </div>
  </div>
</div>

<style>
.init-card {
    background: var(--bg-page);
    border-radius: var(--radius-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
}
.init-card__image {
    width: 100%;
    height: 200px;
    background: var(--bg-elevated);
    flex-shrink: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
}
.init-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
}
  .init-card__image img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }
.init-card__content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    flex: 1;
}
  .init-card__title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: var(--weight-medium);
    font-size: var(--text-2xl);
    line-height: 32px;
    color: var(--content-primary);
  }
  .init-card__desc {
    font-size: var(--text-md);
    line-height: 20px;
    color: var(--content-secondary);
    flex: 1;
  }
  .init-card__bottom {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    margin-top: auto;
  }
  .init-card__date {
    font-size: var(--text-sm);
    line-height: 16px;
    color: var(--content-secondary);
  }
</style>
