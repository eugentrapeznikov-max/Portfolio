---
interface Props {
  company: string;
  date?: string;
  domain?: string;
  domainColor?: string;
  description: string;
  isActive?: boolean;
  isLast?: boolean;
}
const { company, date, domain, domainColor, description, isActive = false, isLast = false } = Astro.props;
---
<div class="tl-row">
  <div class="tl-gutter">
    <div class={`tl-dot ${isActive ? 'tl-dot--active' : ''}`}></div>
    {!isLast && <div class="tl-line"></div>}
  </div>
  <div class="tl-content">
    <span class={`tl-company ${isActive ? 'tl-company--active' : ''}`}>{company}</span>
    {!isActive && date && (
      <div class="tl-meta">
        <span class="tl-date">{date}</span>
        <span class="tl-sep"></span>
        <span class="tl-domain" style={domainColor ? `color:${domainColor}` : ''}>{domain}</span>
      </div>
    )}
    <p class="tl-desc">{description}</p>
  </div>
</div>

<style>
  .tl-row {
    display: flex;
    gap: 18px;
    align-items: flex-start;
    width: 100%;
  }
  .tl-gutter {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 13px;
    flex-shrink: 0;
    padding-top: 2px;
  }
  .tl-dot {
    width: 13px; height: 13px;
    border-radius: 50%;
    border: 2px solid var(--border-strong);
    background: var(--bg-surface);
    flex-shrink: 0;
  }
  .tl-dot--active {
    background: var(--accent-default);
    border-color: var(--accent-default);
    box-shadow: 0 0 0 3px var(--accent-subtle);
  }
  .tl-line {
    width: 2px;
    flex: 1;
    min-height: 135px;
    background: var(--border-default);
    margin-top: 2px;
  }
  .tl-content {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-bottom: 20px;
  }
  .tl-company {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -0.01em;
    color: var(--content-primary);
  }
  .tl-company--active { color: var(--accent-default); }
  .tl-meta {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }
  .tl-date {
    font-size: 11px;
    color: var(--content-secondary);
    letter-spacing: 0.01em;
  }
  .tl-sep {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--content-disabled);
    flex-shrink: 0;
  }
  .tl-domain {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .tl-desc {
    font-size: 12px;
    line-height: 1.5;
    color: var(--content-secondary);
  }
</style>
