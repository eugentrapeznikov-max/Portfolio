---
interface Props {
  company: string;
  date?: string;
  domain?: string;
  domainColor?: string;
  description: string;
  isActive?: boolean;
  isLast?: boolean;
}
const { company, date, domain, domainColor, description, isActive = false, isLast = false } = Astro.props;
---
<div class="tl-item">
  <div class="tl-row">
    <div class="tl-data">
      <span class={`tl-company ${isActive ? 'tl-company--active' : ''}`}>{company}</span>
      {!isActive && date && (
        <div class="tl-meta">
          <span class="tl-date">{date}</span>
          <span class="tl-sep"></span>
          <span class="tl-domain" style={domainColor ? `color:${domainColor}` : ''}>{domain}</span>
        </div>
      )}
    </div>
    <p class="tl-desc">{description}</p>
  </div>
  {!isLast && <div class="tl-divider"></div>}
</div>
<style>
  .tl-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
    width: 100%;
  }
  .tl-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    width: 100%;
  }
  .tl-data {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    width: 100%;
  }
  .tl-company {
    font-family: 'Inter', sans-serif;
    font-weight: var(--weight-semibold);
    font-size: var(--text-lg);
    line-height: 24px;
    letter-spacing: -0.01em;
    color: var(--content-primary);
  }
  .tl-company--active { color: var(--accent-default); }
  .tl-meta {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }
  .tl-date {
    font-size: var(--text-sm);
    line-height: 16px;
    color: var(--content-secondary);
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
  .tl-sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--content-disabled);
    flex-shrink: 0;
  }
  .tl-domain {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .tl-desc {
    font-size: var(--text-md);
    line-height: 20px;
    color: var(--content-secondary);
  }
  .tl-divider {
    height: 1px;
    background: var(--border-default);
    width: 100%;
  }
</style>
