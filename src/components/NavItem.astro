---
interface Props {
  num: string;
  label: string;
  href: string;
  active?: boolean;
}
const { num, label, href, active = false } = Astro.props;
---
<a href={href} class={`nav-item ${active ? 'nav-item--active' : ''}`} data-nav>
  <span class="nav-item__num">{num}</span>
  <span class="nav-item__label">{label}</span>
</a>

<style>
  .nav-item {
    display: flex;
    gap: 12px;
    align-items: center;
    padding: 8px;
    border-radius: var(--radius-sm);
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 300;
    font-size: 12px;
    color: var(--content-secondary);
    transition: background 0.15s, color 0.15s;
    cursor: pointer;
  }
  .nav-item:hover {
    background: var(--bg-elevated);
    color: var(--content-primary);
  }
  .nav-item--active {
    color: var(--accent-default);
    font-weight: 500;
  }
  .nav-item__num { opacity: 0.6; font-size: 11px; }
  .nav-item__label { flex: 1; }
</style>
