---
interface StatRow {
  width: number;
  color: string;
  label: string;
}
interface Props {
  href?: string;
  title: string;
  description: string;
  imageSrc?: string;
  statValue?: string;
  statLabel?: string;
  statRows?: StatRow[];
  layout?: 'full' | 'half';
}
const {
  href,
  title,
  description,
  imageSrc,
  statValue,
  statLabel,
  statRows = [],
  layout = 'full',
} = Astro.props;
const hasStat = statValue && statRows.length > 0;
---
<a class={`work-card work-card--${layout}${href ? " work-card--link" : ""}`} href={href || undefined}>
  <div class="work-card__left">
    <div class="work-card__title-block">
      <h2 class="work-card__title">{title}</h2>
      <p class="work-card__desc">{description}</p>
    </div>
    {hasStat && (
      <div class="work-card__stat">
        <span class="work-card__stat-heading">Numbers</span>
        <div class="work-card__stat-rows">
          {statRows.map((row) => (
            <div class="work-card__stat-row">
              <div
                class="work-card__stat-bar"
                style={`width: ${row.width}px; background: ${row.color};`}
                data-width={row.width}
              ></div>
              <span class="work-card__stat-label">{row.label}</span>
            </div>
          ))}
        </div>
        <div class="work-card__stat-value">
          <span class="work-card__stat-num">{statValue}</span>
          <span class="work-card__stat-sub">{statLabel}</span>
        </div>
      </div>
    )}
  </div>
  <div class="work-card__image">
    {imageSrc
      ? <div class="work-card__image-frame"><img src={imageSrc} alt={title} loading="lazy" /></div>
      : <div class="work-card__image-placeholder"></div>
    }
  </div>
</a>

<style>
.work-card {
    background: var(--bg-page);
    border-radius: var(--radius-xl);
    overflow: hidden;
    position: relative;
    display: flex;
    gap: 32px;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}
  .work-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06), 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  /* Full width — Figma: card px-64, gap-64; Left & Image are both flex:1 (50/50) */
  .work-card--full {
    flex-direction: row;
    gap: 64px;
    padding: 0 64px;
    min-height: 500px;
    align-items: stretch;
  }
  .work-card--full .work-card__left {
    flex: 1 0 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
    padding: 64px 0;
  }
  /* Image column: 64px from the top, bleeds past the bottom and is clipped by the card.
     The image is absolute so its intrinsic height never inflates the card height. */
  .work-card--full .work-card__image {
    flex: 1 0 0;
    min-width: 0;
    align-self: stretch;
    position: relative;
    overflow: hidden;
  }
  .work-card--full .work-card__image-frame {
    position: absolute;
    top: 64px;
    left: 0;
    right: 0;
    bottom: 0;
    overflow: hidden;
  }
  .work-card--full .work-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }
  .work-card--full .work-card__image-placeholder {
    position: absolute;
    inset: 64px 0 0;
    background: var(--bg-surface);
  }

  /* Half width — Figma: card pt-32 px-64, image bleeds to the bottom, no backing */
  .work-card--half {
    flex: 1 1 0;
    min-width: 0;
    flex-direction: column;
    gap: 24px;
    padding: 32px 64px 0;
    min-height: 500px;
  }
  .work-card--half .work-card__left {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .work-card--half .work-card__image {
    flex: 1;
    min-height: 0;
    position: relative;
    overflow: hidden;
  }
  .work-card--half .work-card__image-frame {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .work-card--half .work-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }
  .work-card--half .work-card__image-placeholder {
    position: absolute;
    inset: 0;
    background: var(--bg-surface);
  }

  /* Title block */
.work-card__title-block { display: flex; flex-direction: column; gap: var(--space-12); max-width: 560px; }
.work-card__title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: var(--weight-bold);
    font-size: var(--text-4xl);
    color: var(--content-primary);
    line-height: 40px;
    letter-spacing: -1px;
    margin: 0;
  }
.work-card__desc {
    font-size: var(--text-base);
    line-height: 20px;
    color: var(--content-secondary);
    margin: 0;
  }

  /* Stat block — revealed on card hover */
  .work-card__stat {
    display: flex;
    flex-direction: column;
    gap: 24px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease-out, transform 0.4s ease-out;
    pointer-events: none;
  }
  .work-card--full:hover .work-card__stat {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

.work-card__stat-heading {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: var(--weight-bold);
    font-size: var(--text-4xl);
    color: var(--content-primary);
  }
  .work-card__stat-rows { display: flex; flex-direction: column; gap: 12px; }
  .work-card__stat-row { display: flex; gap: 12px; align-items: center; }
  .work-card__stat-bar {
    height: 12px;
    border-radius: 4px;
    flex-shrink: 0;
    /* collapsed by default, grows in on card hover */
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.55s ease-out;
  }
  .work-card--full:hover .work-card__stat-bar {
    transform: scaleX(1);
  }
  .work-card__stat-row:nth-child(1) .work-card__stat-bar { transition-delay: 0.08s; }
  .work-card__stat-row:nth-child(2) .work-card__stat-bar { transition-delay: 0.2s; }
  .work-card__stat-row:nth-child(3) .work-card__stat-bar { transition-delay: 0.32s; }

 .work-card__stat-label {
    font-size: var(--text-sm);
    color: var(--content-primary);
    white-space: nowrap;
  }
  .work-card__stat-value { display: flex; flex-direction: column; gap: 2px; }
.work-card__stat-num {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: var(--weight-bold);
    font-size: var(--text-5xl);
    color: var(--content-primary);
    line-height: var(--leading-tight);
  }
.work-card__stat-sub {
    font-size: var(--text-sm);
    color: var(--content-secondary);
  }

  /* Image placeholder */
  .work-card__image-placeholder { width: 100%; height: 100%; background: var(--bg-elevated); }

  /* Responsive — Figma Mobile: image height 500px, full width, clipped bottom, no bars */
  @media (max-width: 960px) {
    .work-card--full {
      flex-direction: column;
      padding: 32px 32px 0;
      min-height: auto;
      gap: 24px;
    }
    .work-card--full .work-card__left {
      padding: 0;
    }
    .work-card--full .work-card__image {
      flex: none;
      align-self: auto;
      height: 500px;
    }
    .work-card--full .work-card__image-frame,
    .work-card--full .work-card__image-placeholder {
      inset: 0;
    }
    .work-card--half {
      min-height: auto;
    }
    .work-card--half .work-card__image {
      min-height: 320px;
    }
    /* Bars have no hover state on touch — keep the whole stat block hidden */
    .work-card__stat { display: none; }
  }
</style>
