---
interface StatRow {
  width: number;
  color: string;
  label: string;
}
interface Props {
  title: string;
  description: string;
  imageSrc?: string;
  statValue?: string;
  statLabel?: string;
  statRows?: StatRow[];
  layout?: 'full' | 'half';
}
const {
  title,
  description,
  imageSrc,
  statValue,
  statLabel,
  statRows = [],
  layout = 'full',
} = Astro.props;
const hasStat = statValue && statRows.length > 0;
---
<div class={`work-card work-card--${layout}`}>
  <div class="work-card__left">
    <div class="work-card__title-block">
      <h2 class="work-card__title">{title}</h2>
      <p class="work-card__desc">{description}</p>
    </div>
    {hasStat && (
      <div class="work-card__stat">
        <span class="work-card__stat-heading">Numbers</span>
        <div class="work-card__stat-rows">
          {statRows.map((row) => (
            <div class="work-card__stat-row">
              <div
                class="work-card__stat-bar"
                style={`width: ${row.width}px; background: ${row.color};`}
                data-width={row.width}
              ></div>
              <span class="work-card__stat-label">{row.label}</span>
            </div>
          ))}
        </div>
        <div class="work-card__stat-value">
          <span class="work-card__stat-num">{statValue}</span>
          <span class="work-card__stat-sub">{statLabel}</span>
        </div>
      </div>
    )}
  </div>
  <div class="work-card__image">
    {imageSrc
      ? <img src={imageSrc} alt={title} loading="lazy" />
      : <div class="work-card__image-placeholder"></div>
    }
  </div>
</div>

<style>
.work-card {
    background: var(--bg-surface);
    border-radius: var(--radius-xl);
    overflow: hidden;
    position: relative;
    display: flex;
    gap: 32px;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .work-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
  }

  /* Full width */
  .work-card--full {
    flex-direction: row;
    padding: 64px;
    min-height: 535px;
    align-items: stretch;
  }
  .work-card--full .work-card__left {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .work-card--full .work-card__image {
    width: 468px;
    flex-shrink: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-elevated);
  }
  .work-card--full .work-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  /* Half width */
  .work-card--half {
    flex-direction: column;
    padding: 64px 64px 0;
    height: 560px;
  }
  .work-card--half .work-card__left {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .work-card--half .work-card__image {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    border-radius: 0;
    background: var(--bg-elevated);
  }
  .work-card--half .work-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  /* Title block */
.work-card__title-block { display: flex; flex-direction: column; gap: var(--space-12); }
.work-card__title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: var(--weight-bold);
    font-size: var(--text-4xl);
    color: var(--content-primary);
    line-height: 40px;
    letter-spacing: -1px;
  }
.work-card__desc {
    font-size: var(--text-base);
    line-height: 20px;
    color: var(--content-secondary);
  }

  /* Stat block — hidden by default, shown on hover */
  .work-card__stat {
    display: flex;
    flex-direction: column;
    gap: 24px;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }
  .work-card--full:hover .work-card__stat {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

.work-card__stat-heading {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: var(--weight-bold);
    font-size: var(--text-4xl);
    color: var(--content-primary);
  }
  .work-card__stat-rows { display: flex; flex-direction: column; gap: 12px; }
  .work-card__stat-row { display: flex; gap: 12px; align-items: center; }
  .work-card__stat-bar {
    height: 12px;
    border-radius: 4px;
    flex-shrink: 0;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .work-card--full:hover .work-card__stat-bar { transform: scaleX(1); }
.work-card__stat-bar:nth-child(1) { transition-delay: 0.1s; }
.work-card__stat-bar:nth-child(2) { transition-delay: 0.25s; }
.work-card__stat-bar:nth-child(3) { transition-delay: 0.4s; }

 .work-card__stat-label {
    font-size: var(--text-sm);
    color: var(--content-primary);
    white-space: nowrap;
  }
  .work-card__stat-value { display: flex; flex-direction: column; gap: 2px; }
.work-card__stat-num {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: var(--weight-bold);
    font-size: var(--text-5xl);
    color: var(--content-primary);
    line-height: var(--leading-tight);
  }
.work-card__stat-sub {
    font-size: var(--text-sm);
    color: var(--content-secondary);
  }

  /* Image placeholder */
  .work-card__image-placeholder { width: 100%; height: 100%; background: var(--bg-elevated); }

  /* Responsive */
  @media (max-width: 960px) {
    .work-card--full {
      flex-direction: column;
      padding: 32px;
      min-height: auto;
    }
    .work-card--full .work-card__image {
      width: 100%;
      height: 260px;
    }
    .work-card--half {
      padding: 32px 32px 0;
      height: auto;
    }
    .work-card--half .work-card__image { height: 240px; min-height: 240px; }
    .work-card__stat { opacity: 1; transform: none; }
    .work-card__stat-bar { transform: scaleX(1); }
  }
</style>
