---
interface StatRow {
  width: number;
  color: string;
  label: string;
}
interface Props {
  href?: string;
  title: string;
  description: string;
  imageSrc?: string;
  statValue?: string;
  statLabel?: string;
  statRows?: StatRow[];
  layout?: 'full' | 'half';
}
const {
  href,
  title,
  description,
  imageSrc,
  statValue,
  statLabel,
  statRows = [],
  layout = 'full',
} = Astro.props;
const hasStat = statValue && statRows.length > 0;
---
<a class={`work-card work-card--${layout}${href ? " work-card--link" : ""}`} href={href || undefined}>
  <div class="work-card__left">
    <div class="work-card__title-block">
      <h2 class="work-card__title">{title}</h2>
      <p class="work-card__desc">{description}</p>
    </div>
    {hasStat && (
      <div class="work-card__stat">
        <span class="work-card__stat-heading">Numbers</span>
        <div class="work-card__stat-rows">
          {statRows.map((row) => (
            <div class="work-card__stat-row">
              <div
                class="work-card__stat-bar"
                style={`width: ${row.width}px; background: ${row.color};`}
                data-width={row.width}
              ></div>
              <span class="work-card__stat-label">{row.label}</span>
            </div>
          ))}
        </div>
        <div class="work-card__stat-value">
          <span class="work-card__stat-num">{statValue}</span>
          <span class="work-card__stat-sub">{statLabel}</span>
        </div>
      </div>
    )}
  </div>
  <div class="work-card__image">
    {imageSrc
      ? <div class="work-card__image-frame"><img src={imageSrc} alt={title} loading="lazy" /></div>
      : <div class="work-card__image-placeholder"></div>
    }
  </div>
</a>

<style>
.work-card {
    background: var(--bg-surface);
    border-radius: var(--radius-xl);
    overflow: hidden;
    position: relative;
    display: flex;
    gap: 32px;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .work-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06), 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  /* Full width */
  .work-card--full {
    flex-direction: row;
    /* reserve the right half of the card for the (absolutely positioned) image */
    padding: 64px calc(50% + 48px) 64px 64px;
    min-height: 620px;
    align-items: stretch;
  }
  .work-card--full .work-card__left {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
  }
  /* Image container: right half, full card height, clipped by the card's overflow */
  .work-card--full .work-card__image {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 50%;
  }
  .work-card--full .work-card__image-frame {
    position: static;
    width: 100%;
    height: 100%;
    border-radius: 0;
    overflow: visible;
    background: transparent;
    box-shadow: none;
  }
  .work-card--full .work-card__image img,
  .work-card--full .work-card__image-placeholder {
    width: 100%;
    height: 100%;
    /* pushed down 64px; the extra height spills below the card and is clipped */
    margin-top: 64px;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  /* Half width */
  .work-card--half {
    flex-direction: column;
    padding: 36px 36px 0;
    min-height: 580px;
  }
  .work-card--half .work-card__left {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .work-card--half .work-card__image {
    flex: 1;
    min-height: 0;
    padding-top: 24px;
    display: flex;
    align-items: flex-end;
  }
  .work-card--half .work-card__image-frame {
    width: 100%;
    height: 100%;
    min-height: 290px;
    border-radius: 28px 28px 0 0;
    overflow: hidden;
    background: var(--bg-elevated);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.4);
  }
  .work-card--half .work-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  /* Title block */
.work-card__title-block { display: flex; flex-direction: column; gap: var(--space-12); max-width: 560px; }
.work-card__title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: var(--weight-bold);
    font-size: var(--text-4xl);
    color: var(--content-primary);
    line-height: 40px;
    letter-spacing: -1px;
    margin: 0;
  }
.work-card__desc {
    font-size: var(--text-base);
    line-height: 20px;
    color: var(--content-secondary);
    margin: 0;
  }

  /* Stat block */
  .work-card__stat {
    display: flex;
    flex-direction: column;
    gap: 24px;
    opacity: 1;
    transform: none;
    transition: none;
    pointer-events: auto;
  }

.work-card__stat-heading {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: var(--weight-bold);
    font-size: var(--text-4xl);
    color: var(--content-primary);
  }
  .work-card__stat-rows { display: flex; flex-direction: column; gap: 12px; }
  .work-card__stat-row { display: flex; gap: 12px; align-items: center; }
  .work-card__stat-bar {
    height: 12px;
    border-radius: 4px;
    flex-shrink: 0;
    /* hidden by default, revealed on card hover */
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s ease-out;
  }
  .work-card--full:hover .work-card__stat-bar { transform: scaleX(1); }
.work-card__stat-bar:nth-child(1) { transition-delay: 0.1s; }
.work-card__stat-bar:nth-child(2) { transition-delay: 0.25s; }
.work-card__stat-bar:nth-child(3) { transition-delay: 0.4s; }

 .work-card__stat-label {
    font-size: var(--text-sm);
    color: var(--content-primary);
    white-space: nowrap;
  }
  .work-card__stat-value { display: flex; flex-direction: column; gap: 2px; }
.work-card__stat-num {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: var(--weight-bold);
    font-size: var(--text-5xl);
    color: var(--content-primary);
    line-height: var(--leading-tight);
  }
.work-card__stat-sub {
    font-size: var(--text-sm);
    color: var(--content-secondary);
  }

  /* Image placeholder */
  .work-card__image-placeholder { width: 100%; height: 100%; background: var(--bg-elevated); }

  /* Responsive */
  @media (max-width: 960px) {
    .work-card--full {
      flex-direction: column;
      /* image is back in normal flow on mobile — reset the reserved right padding */
      padding: 32px 32px 0;
      min-height: auto;
      align-items: stretch;
      gap: 32px;
    }
    .work-card--full .work-card__image {
      position: relative;
      top: auto;
      right: auto;
      bottom: auto;
      width: auto;
      height: 500px;
      /* bleed to the card's side/bottom edges so the image is clipped by the card */
      margin: 0 -32px;
      overflow: hidden;
    }
    .work-card--full .work-card__image-frame {
      width: 100%;
      height: 100%;
    }
    .work-card--full .work-card__image img,
    .work-card--full .work-card__image-placeholder {
      /* no top offset on mobile; bottom is cropped via object-position */
      margin-top: 0;
      height: 100%;
    }
    .work-card--half {
      padding: 32px 32px 0;
      min-height: auto;
    }
    .work-card--half .work-card__image {
      padding-top: 16px;
    }
    .work-card--half .work-card__image-frame {
      min-height: 220px;
      border-radius: 20px 20px 0 0;
    }
    .work-card__stat { display: none; }
  }
</style>
