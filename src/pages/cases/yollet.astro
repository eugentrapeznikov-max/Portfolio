---
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Yollet — Eugen Trapeznikov</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --bg:#ffffff; --bg2:#f5f4f1; --bg3:#eceae4; --text:#1a1a1a; --text2:#6b6b6b; --text3:#a8a8a0; --border:rgba(0,0,0,0.08); --acc:#E8601A; }
    html.dark { --bg:#111110; --bg2:#1a1918; --bg3:#232220; --text:#e8e6e0; --text2:#888580; --text3:#555250; --border:rgba(255,255,255,0.07); }
    html, body { height: 100%; }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); transion: background .3s, color .3s; }
    .shell { display: flex; height: 100vh; overflow: hidden; }
    .sidebar { width: 224px; flex-shrink: 0; border-right: 0.5px solid var(--border); padding: 24px 20px; display: flex; flex-direction: column; background: var(--bg2); height: 100vh; position: sticky; top: 0; }
    .profile { display: flex; align-items: center; gap: 10px; margin-bottom: 18px; }
    .avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--bg3); border: 0.5px solid var(--border); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 600; color: var(--text3); }
    .profile-name { font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 700; color: var(--text); letter-spacing: -0.01em; }
    .descriptor-block { margin-bottom: 20px; padding-bottom: 20px; border-bottom: 0.5px solid var(--border); }
    .role-primary { font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 5px; }
    .role-tags { font-size: 11px; color: var(--text2); line-height: 2; margin-bottom: 10px; }
    .role-tags s { color: var(--text3); text-decoration-color: var(--acc); text-decoration-thickness: 1.5px; }
    .role-tags .sep { margin: 0 4px; color: var(--text3); }
    .bio { font-size: 11px; line-height: 1.6; color: var(--text3); }
    .bio em { font-style: normal; color: var(--acc); }
    .nav-list { display: flex; flex-direction: column; gap: 2px; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 7px 0; cursor: pointer; color: var(--text2); font-size: 13px; text-decoration: none; transition: color .2s; }
    .nav-item:hover { color: var(--text); }
    .nav-item.active { color: var(--text); }
    .nav-num { font-family: 'Space Grotesk', sans-serif; font-size: 10px; font-weight: 700; color: var(--text3); min-width: 16px; }
    .nav-item.active .nav-num { color: var(--acc); }
    .nav-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--acc); margin-left: auto; opacity: 0; }
    .nav-item.active .nav-dot { opacity: 1; }
    .divider { height: 0.5px; background: var(--border); margin: 14px 0; }
    .nav-small { display: flex; align-items: center; gap: 10px; font-size: 12px; color: var(--text3); padding: 5px 0; cursor: pointer; text-decoration: none; transition: color .2s; }
    .nav-small:hover { color: var(--acc); }
    .sidebar-bottom { margin-top: auto; padding-top: 16px; border-top: 0.5px solid var(--border); display: flex; flex-direction: column; gap: 10px; }
    .status-row { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--text3); }
    .status-dot { width: 5px; height: 5px; border-radius: 50%; background: #3db87a; flex-shrink: 0; }
    .theme-toggle { display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 11px; color: var(--text3); background: none; border: none; padding: 0; transition: color .2s; }
    .theme-toggle:hover { color: var(--text); }
    .toggle-track { width: 28px; height: 16px; border-radius: 8px; background: var(--bg3); border: 0.5px solid var(--border); position: relative; flex-shrink: 0; }
    .toggle-knob { width: 10px; height: 10px; border-radius: 50%; background: var(--text3); position: absolute; top: 2px; left: 2px; transition: transform .25s, background .25s; }
    html.dark .toggle-knob { transform: translateX(12px); background: var(--acc); }
    .main { flex: 1; padding: 40px 48px; overflow-y: auto; height: 100vh; max-width: 800px; }
    .back-link { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text3); text-decoration: none; margin-bottom: 40px; transition: color .2s; }
    .back-link:hover { color: var(--acc); }
    .case-header { margin-bottom: 48px; }
    .case-tags { display: flex; gap: 6px; margin-bottom: 16px; }
    .case-tag { font-size: 11px; font-weight: 500; padding: 3px 10px; border-radius: 20px; background: rgba(232,96,26,0.08); color: var(--acc); border: 0.5px solid rgba(232,96,26,0.2); }
    .case-title { font-family: 'Space Grotesk', sans-serif; font-size: 40px; font-weight: 700; line-height: 1.05; letter-spacing: -0.025em; color: var(--text); margin-bottom: 16px; }
    .case-subtitle { font-size: 16px; line-height: 1.6; color: var(--text2); max-width: 560px; margin-bottom: 28px; }
    .meta-row { display: flex; gap: 32px; padding: 20px 0; border-top: 0.5px solid var(--border); border-bottom: 0.5px solid var(--border); }
    .meta-item { display: flex; flex-direction: column; gap: 3px; }
    .meta-label { font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text3); }
    .meta-value { font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 700; color: var(--text); }
    .section { margin-bottom: 56px; }
    .section-label { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text3); margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }
    .section-label::after { content: ''; flex: 1; height: 0.5px; background: var(--border); }
    .section-title { font-family: 'Space Grotesk', sans-serif; font-size: 22px; font-weight: 700; letter-spacing: -0.02em; color: var(--text); margin-bottom: 12px; }
    .section-text { font-size: 15px; line-height: 1.7; color: var(--text2); margin-bottom: 16px; }
    .img-placeholder { width: 100%; border-radius: 12px; background: var(--bg2); border: 0.5px solid var(--border); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; color: var(--text3); font-size: 13px; margin-bottom: 10px; }
    .img-caption { font-size: 12px; color: var(--text3); text-align: center; margin-bottom: 32px; }
    .metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin: 24px 0; }
    .metric-card { background: var(--bg2); border-radius: 10px; border: 0.5px solid var(--border); padding: 16px; }
    .metric-num { font-family: 'Space Grotesk', sans-serif; font-size: 28px; font-weight: 700; color: var(--acc); letter-spacing: -0.02em; margin-bottom: 4px; }
    .metric-desc { font-size: 12px; color: var(--text3); line-height: 1.4; }
    .steps { display: flex; flex-direction: column; gap: 0; margin: 20px 0; }
    .step { display: flex; gap: 16px; padding: 16px 0; border-bottom: 0.5px solid var(--border); }
    .step:last-child { border-bottom: none; }
    .step-num { font-family: 'Space Grotesk', sans-serif; font-size: 11px; font-weight: 700; color: var(--acc); min-width: 24px; padding-top: 2px; }
    .step-title { font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
    .step-text { font-size: 13px; color: var(--text2); line-height: 1.6; }
    .next-case { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px; border-radius: 12px; background: var(--bg2); border: 0.5px solid var(--border); text-decoration: none; margin-top: 64px; transition: border-color .2s; }
    .next-case:hover { border-color: rgba(232,96,26,0.35); }
    .next-label { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text3); margin-bottom: 4px; }
    .next-title { font-family: 'Space Grotesk', sans-serif; font-size: 16px; font-weight: 700; color: var(--text); }
    .next-arrow { font-size: 20px; color: var(--text3); transition: color .2s, transform .2s; }
    .next-case:hover .next-arrow { color: var(--acc); transform: translateX(4px); }
  </style>
</head>
<body>
<div class="shell">
  <aside class="sidebar">
    <div class="profile">
      <div class="avatar">ET</div>
      <div class="profile-name">Eugen Trapeznikov</div>
    </div>
    <div class="descriptor-block">
      <div class="role-primary">Product Designer</div>
      <div class="role-tags">
        <s>Pixel Pusher</s><span class="sep">·</span>Decision Maker<span class="sep">·</span>Product Mind<span class="sep">·</span>T-shaped
      </div>
      <p class="bio">I get a kick from untangling logic and visual plems. Design, to me, is <em>communication</em> — with people and with technology.</p>
    </div>
    <nav class="nav-list">
      <a href="/" class="nav-item active"><span class="nav-num">01</span>Work<span class="nav-dot"></span></a>
      <a href="#" class="nav-item"><span class="nav-num">02</span>About</a>
      <a href="#" class="nav-item"><span class="nav-num">03</span>Experience</a>
      <a href="#" class="nav-item"><span class="nav-num">04</span>Contact</a>
    </nav>
    <div class="divider"></div>
    <a href="https://linkedin.com/in/evgenii-trapeznikov/" target="_blank" class="nav-small"><span style="font-size:10px;min-width:16px;font-weight:700">↗</span>LinkedIn</a>
    <a href="https://t.me/EvgeniiTznikov" target="_blank" class="nav-small"><span style="font-size:10px;min-width:16px;font-weight:700">↗</span>Telegram</a>
    <a href="#" class="nav-small" style="color:var(--acc)"><span style="font-size:10px;min-width:16px">↓</span>CV</a>
    <div class="sidebar-bottom">
      <div class="status-row"><span class="status-dot"></span>Open to work · Belgrade</div>
      <button class="theme-toggle" id="themeBtn" aria-label="Toggle theme">
        <div class="toggle-track"><div class="toggle-knob"></div></div>
        <span id="themeLabel">Light mode</span>
      </button>
    </div>
  </aside>
  <main class="main">
    <a href="/" class="back-link">← Back to work</a>
    <div class="case-header">
      <div class="case-tags">
        <span class="case-tag">#crypto</span>
        <span class="case-tag">#fintech</span>
        <span class="case-tag">#0→1</span>
      </div>
      <h1 class="case-title">Yollet —<br>Crypto Wallet</h1>
      <p class="case-subtitle">Designing a non-custodial crypto walilt-in crypto↔fiat exchange from scratch — end-to-end, in 6 months.</p>
      <div class="meta-row">
        <div class="meta-item"><span class="meta-label">Role</span><span class="meta-value">Lead Product Designer</span></div>
        <div class="meta-item"><span class="meta-label">Timeline</span><span class="meta-value">Sep 2025 — Feb 2026</span></div>
        <div class="meta-item"><span class="meta-label">Platform</span><span class="meta-value">iOS & Android</span></div>
        <div class="meta-item"><span class="meta-label">Team</span><span class="meta-value">CEO + 3 Engineers</span></div>
      </div>
    </div>
    <div class="section">
      <div class="section-label">01 — Overview</div>
      <h2 class="section-title">The challenge</h2>
      <p class="section-text">Yollet needed a crypto wallet that didn't feel like crypto. The target audience — people moving between crypto and fiat regularly, without custodial risk. No existing wallet solved both sides cleanly.</p>
      <p class="sectI joined as the sole designer and owned everything: discovery, research, IA, UX, UI, prototyping, and dev handoff. Built the design process from zero alongside the product.</p>
    </div>
    <div class="section">
      <div class="section-label">02 — Process</div>
      <h2 class="section-title">How I approached it</h2>
      <div class="steps">
        <div class="step"><span class="step-num">01</span><div><div class="step-title">Discovery & research</div><div class="step-text">Defined key user scenarios, mapped jobs-to-be-done, interviewed crypto-native and crypto-curious users. Identified the main friction: trust and complexity of exchange flows.</div></div></div>
        <div class="step"><span class="step-num">02</span><div><div class="step-title">Information architecture</div><div class="step-text">Mapped all user flows — wallet, exchange, history, settings. Ran multiple IA workshops with the CEO to align on product decisions before touching UI.</div></div></div>
    <div class="step"><span class="step-num">03</span><div><div class="step-title">UX & UI design</div><div class="step-text">Designed core wallet + exchange experiences. Built interactive prototypes in Figma Make for user testing. Iterated on the exchange flow 4 times based on feedback.</div></div></div>
        <div class="step"><span class="step-num">04</span><div><div class="step-title">Dev handoff</div><div class="step-text">Produced dev-ready specs, component documentation, and edge case guidelines. Worked directly with engineers to ensure pixel-accurate implementation.</div></div></div>
      </div>
    </div>
    <div class="section">
      <div class="section-label">03 — Visuals</div>
      <h2 class="section-title">Selected screens</h2>
      <div class="img-placeholder" style="height:320px"><span style="font-size:24px">🖼</span><span>Add mockup — wallet home screen</span></div>
      <p class="img-caption">Wallet home — balance overview and quick actions</p>
      <div style="display:gridmplate-columns:1fr 1fr;gap:12px">
        <div><div class="img-placeholder" style="height:240px"><span style="font-size:24px">🖼</span><span>Exchange flow</span></div><p class="img-caption">Crypto → fiat exchange</p></div>
        <div><div class="img-placeholder" style="height:240px"><span style="font-size:24px">🖼</span><span>Onboarding</span></div><p class="img-caption">Onboarding & wallet setup</p></div>
      </div>
    </div>
    <div class="section">
      <div class="section-label">04 — Outcome</div>
      <h2 class="section-title">Results</h2>
      <p class="section-text">Delivered a complete, production-ready design system and all core flows in 6 months — from zero to launch-ready.</p>
      <div class="metrics">
        <div class="metric-card"><div class="metric-num">0→1</div><div class="metric-desc">Full product designed from scratch</div></div>
        <div class="metric-card"><div class="metric-num">6mo</div><div class="metric-desc">Discovery to dev-ready handoff</div></div>
    ss="metric-card"><div class="metric-num">100%</div><div class="metric-desc">Solo designer ownership</div></div>
      </div>
    </div>
    <a href="/cases/newsfeed" class="next-case">
      <div><div class="next-label">Next case</div><div class="next-title">AI Sports Newsfeed</div></div>
      <span class="next-arrow">→</span>
    </a>
  </main>
</div>
<script>
  const btn = document.getElementById('themeBtn');
  const label = document.getElementById('themeLabel');
  let dark = false;
  btn.addEventListener('click', () => {
    dark = !dark;
    document.documentElement.classList.toggle('dark', dark);
    label.textContent = dark ? 'Dark mode' : 'Light mode';
  });
</script>
</body>
</html>
