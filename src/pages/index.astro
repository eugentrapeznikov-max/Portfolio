---
// src/pages/index.astro
// Eugen Trapeznikov — Portfolio Homepage
// Stack: Astro, vanilla CSS, vanilla JS
// Design source: Figma node 93:3694
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Eugen Trapeznikov — Senior Product Designer. Fintech & Sporttech." />
  <title>Eugen Trapeznikov — Product Designer</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    /* ─── Design Tokens ──────────────────────────────────── */
    :root {
      --bg:        #ffffff;
      --bg2:       #f6f6f6;
      --bg3:       #ebebeb;
      --text:      #171717;
      --secondary: #666666;
      --border:    rgba(0, 0, 0, 0.08);
      --accent:    #e8601a;
      --radius-lg: 24px;
      --radius-md: 16px;
      --radius-sm: 8px;
      --sidebar-w: 360px;

      /* timeline dot colors */
      --clr-fintech-1: #6b5fd4;
      --clr-media:     #2e9e6e;
      --clr-fintech-2: #2b3cf5;
      --clr-saas:      #2e9e6e;
      --clr-agency:    #545454;
    }

    [data-theme="dark"] {
      --bg:        #111110;
      --bg2:       #1a1918;
      --bg3:       #242321;
      --text:      #e8e6e0;
      --secondary: #888882;
      --border:    rgba(255, 255, 255, 0.08);
    }

    /* ─── Reset ──────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
    }

    img { display: block; max-width: 100%; }
    a { text-decoration: none; color: inherit; }
    p { word-break: break-word; }

    /* ─── Layout ─────────────────────────────────────────── */
    .layout {
      display: flex;
      width: 100%;
      min-height: 100vh;
      align-items: flex-start;
    }

    /* ─── Sidebar ────────────────────────────────────────── */
    .sidebar {
      width: var(--sidebar-w);
      min-width: var(--sidebar-w);
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
      background: var(--bg);
      padding: 32px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      scrollbar-width: none;
    }
    .sidebar::-webkit-scrollbar { display: none; }

    /* ─── Cards (shared) ─────────────────────────────────── */
    .card {
      background: var(--bg2);
      border-radius: var(--radius-lg);
      overflow: hidden;
    }

    /* ─── Summary card ───────────────────────────────────── */
    .summary-card {
      padding: 20px 16px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .summary-title {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .summary-title .name {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 16px;
      color: var(--text);
    }
    .summary-title .role {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 300;
      font-size: 12px;
      color: var(--secondary);
    }

    .summary-point {
      display: flex;
      flex-direction: column;
      gap: 4px;
      font-size: 12px;
    }
    .summary-point .label {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 300;
      color: var(--text);
    }
    .summary-point .value {
      font-family: 'Inter', sans-serif;
      font-weight: 300;
      color: var(--secondary);
      line-height: 1.5;
    }

    /* ─── Nav ────────────────────────────────────────────── */
    .nav {
      display: flex;
      flex-direction: column;
      gap: 4px;
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 300;
      font-size: 12px;
      color: var(--secondary);
    }
    .nav-item {
      display: flex;
      gap: 12px;
      align-items: center;
      padding: 8px;
      border-radius: var(--radius-sm);
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
    }
    .nav-item:hover { background: var(--bg3); }
    .nav-item.active { color: var(--accent); font-weight: 500; }
    .nav-item .num { white-space: nowrap; }
    .nav-item .label { flex: 1; }

    /* ─── Theme toggle ───────────────────────────────────── */
    .theme-row {
      display: flex;
      gap: 16px;
      align-items: center;
      padding: 8px;
    }
    .theme-label {
      flex: 1;
      font-family: 'Inter', sans-serif;
      font-weight: 500;
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--text);
    }
    .switch {
      width: 52px;
      height: 24px;
      background: var(--accent);
      border-radius: 100px;
      padding: 2px 4px;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      cursor: pointer;
      transition: background 0.2s;
      border: none;
      flex-shrink: 0;
    }
    .switch[aria-checked="false"] { justify-content: flex-start; background: var(--bg3); }
    .switch-thumb {
      width: 16px;
      height: 16px;
      background: #fff;
      border-radius: 50%;
      transition: transform 0.2s;
    }
    [data-theme="dark"] .switch { background: var(--accent); justify-content: flex-end; }

    /* ─── Timeline ───────────────────────────────────────── */
    .timeline-card {
      padding: 20px 16px;
    }
    .timeline-header {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 42px;
    }
    .timeline-eyebrow {
      font-family: 'Inter', sans-serif;
      font-weight: 500;
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #9b9b93;
    }
    .timeline-heading {
      font-family: 'Inter', sans-serif;
      font-weight: 600;
      font-size: 22px;
      letter-spacing: -0.01em;
      color: var(--text);
    }

    .timeline-list { display: flex; flex-direction: column; }

    .timeline-item {
      display: flex;
      gap: 18px;
      align-items: flex-start;
    }

    .timeline-line {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 13px;
      flex-shrink: 0;
    }
    .timeline-dot {
      width: 13px;
      height: 13px;
      border-radius: 50%;
      border: 2px solid currentColor;
      background: var(--bg2);
      flex-shrink: 0;
    }
    .timeline-item:first-child .timeline-dot { color: var(--accent); border-color: var(--accent); }
    .timeline-connector {
      width: 2px;
      height: 72px;
      background: #dddde0;
      margin-top: 0;
    }
    .timeline-item:last-child .timeline-connector { display: none; }

    .timeline-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding-bottom: 32px;
    }
    .timeline-item:last-child .timeline-content { padding-bottom: 0; }

    .timeline-company {
      font-family: 'Inter', sans-serif;
      font-weight: 600;
      font-size: 16px;
      letter-spacing: -0.01em;
      color: var(--text);
    }
    .timeline-item:first-child .timeline-company { color: var(--accent); }

    .timeline-meta {
      display: flex;
      gap: 10px;
      align-items: center;
    }
    .timeline-date {
      font-family: 'Inter', sans-serif;
      font-weight: 400;
      font-size: 12px;
      letter-spacing: 0.01em;
      color: var(--secondary);
      white-space: nowrap;
    }
    .timeline-dot-sep {
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: var(--secondary);
      flex-shrink: 0;
    }
    .timeline-domain {
      font-family: 'Inter', sans-serif;
      font-weight: 500;
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      white-space: nowrap;
    }
    .timeline-desc {
      font-family: 'Inter', sans-serif;
      font-weight: 400;
      font-size: 13px;
      line-height: 1.5;
      color: var(--secondary);
    }

    /* ─── Main ───────────────────────────────────────────── */
    .main {
      flex: 1;
      min-width: 0;
      padding: 32px 32px 32px 0;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    /* ─── Hero ───────────────────────────────────────────── */
    .hero {
      background: var(--bg2);
      border-radius: 32px;
      padding: 32px 64px;
      display: flex;
      flex-direction: column;
      gap: 32px;
      overflow: hidden;
    }

    .hero-top {
      display: flex;
      gap: 32px;
      align-items: center;
    }

    .avatar {
      width: 56px;
      height: 56px;
      border-radius: 28px;
      background: var(--accent);
      overflow: hidden;
      flex-shrink: 0;
    }
    .avatar img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }

    .social-links {
      flex: 1;
      display: flex;
      gap: 16px;
      align-items: center;
      justify-content: flex-end;
    }
    .social-btn {
      width: 48px;
      height: 48px;
      background: var(--bg);
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.15s, transform 0.15s;
      flex-shrink: 0;
    }
    .social-btn:hover { opacity: 0.7; transform: translateY(-1px); }
    .social-btn svg { width: 24px; height: 24px; }

    .hero-headline {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 44px;
      line-height: 60px;
      color: var(--text);
    }

    .hero-actions {
      display: flex;
      align-items: center;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 16px 32px;
      background: var(--text);
      color: var(--bg);
      border-radius: 100px;
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 500;
      font-size: 16px;
      line-height: 20px;
      white-space: nowrap;
      transition: opacity 0.15s, transform 0.15s;
      border: none;
      cursor: pointer;
    }
    .btn-primary:hover { opacity: 0.85; transform: translateY(-1px); }

    /* ─── Works block ────────────────────────────────────── */
    .works-block {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    /* Work card — full width */
    .work-card {
      background: var(--bg2);
      border-radius: var(--radius-lg);
      padding: 64px;
      position: relative;
      overflow: hidden;
      min-height: 535px;
    }

    .work-card-title {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 26px;
      color: var(--text);
      margin-bottom: 10px;
    }
    .work-card-desc {
      font-family: 'Inter', sans-serif;
      font-weight: 400;
      font-size: 13px;
      line-height: 1.5;
      color: var(--secondary);
    }

    .work-card-image {
      position: absolute;
      right: 64px;
      top: 45px;
      width: 380px;
      height: 490px;
      border-radius: 12px;
      overflow: hidden;
    }
    .work-card-image img {
      width: 100%;
      height: 103.54%;
      object-fit: cover;
      margin-top: -0.03%;
    }

    .work-card-image--sports {
      right: 0;
      top: 0;
      width: 380px;
      height: 100%;
      border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
    }
    .work-card-image--sports img {
      height: 100%;
      margin-top: 0;
    }

    /* Numbers card overlay */
    .numbers-overlay {
      position: absolute;
      left: 64px;
      bottom: 64px;
      backdrop-filter: blur(5px);
      -webkit-backdrop-filter: blur(5px);
      background: rgba(255,255,255,0.7);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: var(--radius-sm);
      padding: 20px 24px;
      display: flex;
      flex-direction: column;
      gap: 24px;
      min-width: 240px;
    }
    [data-theme="dark"] .numbers-overlay { background: rgba(17,17,16,0.7); }

    .numbers-title {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 26px;
      color: var(--text);
    }
    .numbers-rows {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .numbers-row {
      display: flex;
      gap: 12px;
      align-items: center;
    }
    .numbers-bar {
      height: 12px;
      border-radius: 4px;
      flex-shrink: 0;
    }
    .numbers-row-text {
      font-family: 'Inter', sans-serif;
      font-weight: 400;
      font-size: 12px;
      color: var(--text);
      white-space: nowrap;
    }
    .numbers-stat {
      display: flex;
      flex-direction: column;
    }
    .numbers-stat-val {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 32px;
      color: var(--text);
      line-height: 1;
    }
    .numbers-stat-label {
      font-family: 'Inter', sans-serif;
      font-weight: 500;
      font-size: 12px;
      color: var(--text);
      white-space: nowrap;
    }

    /* Two-column card row */
    .work-row {
      display: flex;
      gap: 16px;
    }
    .work-card-half {
      flex: 1;
      min-width: 0;
      background: var(--bg2);
      border-radius: var(--radius-lg);
      padding-top: 64px;
      padding-left: 64px;
      padding-right: 64px;
      height: 564px;
      display: flex;
      flex-direction: column;
      gap: 32px;
      overflow: hidden;
    }
    .work-card-half-image {
      flex: 1;
      min-height: 0;
      overflow: hidden;
      border-radius: 0;
    }
    .work-card-half-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top;
    }

    /* ─── Sections heading ───────────────────────────────── */
    .section-heading {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 44px;
      line-height: 60px;
      color: var(--text);
    }

    /* ─── Initiatives ────────────────────────────────────── */
    .initiatives-block {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .initiatives-list {
      display: flex;
      gap: 12px;
    }
    .initiative-card {
      flex: 1;
      min-width: 0;
      background: var(--bg2);
      border-radius: var(--radius-md);
      padding: 32px;
    }
    .initiative-title {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 26px;
      color: var(--text);
      margin-bottom: 10px;
    }
    .initiative-desc {
      font-family: 'Inter', sans-serif;
      font-weight: 400;
      font-size: 13px;
      line-height: 1.5;
      color: var(--secondary);
    }

    /* ─── Contacts ───────────────────────────────────────── */
    .contacts-block {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }
    .contacts-card {
      background: var(--bg2);
      border-radius: var(--radius-lg);
      min-height: 535px;
      padding: 64px;
      display: flex;
      flex-direction: column;
      gap: 32px;
      align-items: flex-start;
      justify-content: center;
    }
    .contacts-email {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 32px;
      color: var(--text);
      word-break: break-all;
    }
    .contacts-email:hover { color: var(--accent); }
    .contacts-links {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }
    .contacts-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      background: var(--bg3);
      border-radius: 100px;
      font-family: 'Inter', sans-serif;
      font-weight: 500;
      font-size: 14px;
      color: var(--text);
      transition: background 0.15s;
    }
    .contacts-link:hover { background: var(--accent); color: #fff; }

    /* ─── Sections wrapper ───────────────────────────────── */
    .sections {
      display: flex;
      flex-direction: column;
      gap: 64px;
    }

    /* ─── Mobile nav header ──────────────────────────────── */
    .mobile-header {
      display: none;
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--bg);
      border-bottom: 0.5px solid var(--border);
      padding: 0 16px;
      height: 64px;
      align-items: center;
      justify-content: space-between;
    }
    .mobile-logo {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 16px;
      color: var(--text);
    }
    .mobile-menu-btn {
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: none;
      background: none;
      cursor: pointer;
      color: var(--text);
    }

    /* Mobile nav drawer */
    .mobile-nav {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 200;
      background: var(--bg);
      padding: 32px 16px;
      flex-direction: column;
      gap: 8px;
    }
    .mobile-nav.open { display: flex; }
    .mobile-nav-close {
      align-self: flex-end;
      width: 40px;
      height: 40px;
      border: none;
      background: none;
      cursor: pointer;
      color: var(--text);
      font-size: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
    }
    .mobile-nav .nav-item {
      font-size: 24px;
      padding: 16px;
    }

    /* ─── Responsive ─────────────────────────────────────── */
    @media (max-width: 900px) {
      .layout { flex-direction: column; }
      .sidebar { display: none; }
      .mobile-header { display: flex; }
      .main { padding: 16px; }

      .hero {
        padding: 32px 32px 0;
        border-radius: 16px;
      }
      .hero-headline { font-size: 28px; line-height: 38px; }

      .work-card {
        padding: 32px;
        min-height: auto;
      }
      .work-card-image {
        position: relative;
        right: auto;
        top: auto;
        width: 100%;
        height: 300px;
        margin-top: 32px;
        border-radius: 12px;
      }
      .work-card-image img { height: 100%; margin-top: 0; }

      .work-row { flex-direction: column; }
      .work-card-half {
        padding: 32px 32px 0;
        height: auto;
      }
      .work-card-half-image { height: 280px; min-height: 280px; }

      .work-card-image--sports {
        position: relative;
        right: auto;
        top: auto;
        width: 100%;
        border-radius: 0 0 var(--radius-lg) var(--radius-lg);
      }

      .numbers-overlay {
        position: relative;
        left: auto;
        bottom: auto;
        margin-top: 32px;
        min-width: 0;
      }

      .initiatives-list { flex-direction: column; }
      .section-heading { font-size: 32px; line-height: 44px; }
      .contacts-email { font-size: 22px; }
      .hero-headline { font-size: 28px; }
    }

    @media (max-width: 600px) {
      .social-links { gap: 8px; }
      .hero { padding: 24px 20px 0; }
      .hero-headline { font-size: 22px; line-height: 32px; }
      .work-card { padding: 24px; }
      .work-card-half { padding: 24px 24px 0; }
      .contacts-card { padding: 32px 24px; }
      .contacts-email { font-size: 18px; }
    }
  </style>
</head>

<body>

  <!-- Mobile header -->
  <header class="mobile-header">
    <span class="mobile-logo">ET</span>
    <button class="mobile-menu-btn" id="menuOpen" aria-label="Open menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </header>

  <!-- Mobile nav drawer -->
  <nav class="mobile-nav" id="mobileNav">
    <button class="mobile-nav-close" id="menuClose" aria-label="Close menu">✕</button>
    <a href="#home" class="nav-item" onclick="closeMobileNav()"><span class="num">01</span><span class="label">/ Home</span></a>
    <a href="#works" class="nav-item" onclick="closeMobileNav()"><span class="num">02</span><span class="label">/ Selected Works</span></a>
    <a href="#initiatives" class="nav-item" onclick="closeMobileNav()"><span class="num">03</span><span class="label">/ Initiatives</span></a>
    <a href="#contact" class="nav-item" onclick="closeMobileNav()"><span class="num">04</span><span class="label">/ Contact</span></a>
  </nav>

  <div class="layout">

    <!-- ─── SIDEBAR ─────────────────────────────────────── -->
    <aside class="sidebar">

      <!-- Summary card -->
      <div class="card">
        <div class="summary-card">
          <div class="summary-title">
            <span class="name">Eugen Trapeznikov</span>
            <span class="role">Product Designer</span>
          </div>
          <div class="summary-point">
            <span class="label">Experience</span>
            <span class="value">7 years</span>
          </div>
          <div class="summary-point">
            <span class="label">Platforms</span>
            <span class="value">Mobile &amp; Desktop,<br>Strong focus on mobile applications</span>
          </div>
          <div class="summary-point">
            <span class="label">Domains</span>
            <span class="value">Fintech, Media, B2C mostly</span>
          </div>
          <div class="summary-point">
            <span class="label">Teams</span>
            <span class="value">Design teams &amp; cross-functional product teams, some experience in startups and freelance</span>
          </div>

          <!-- Nav -->
          <nav class="nav">
            <a href="#home" class="nav-item active">
              <span class="num">01</span>
              <span class="label">/ Home</span>
            </a>
