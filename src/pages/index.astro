---
import SidebarLayout from '../layouts/SidebarLayout.astro';
import Avatar from '../components/Avatar.astro';
import SocialButton from '../components/SocialButton.astro';
import WorkCard from '../components/WorkCard.astro';
import InitiativeCard from '../components/InitiativeCard.astro';

const works = [
  {
    href: '/cases/yollet',
    title: 'Yollet — Neo Bank',
    description: 'From scattered screens to a cohesive product',
    imageSrc: '/works/main-screen-yollet.png',
    layout: 'full' as const,
    statValue: '1',
    statLabel: 'Ready-to-launch Crypto Bank',
    statRows: [
      { width: 100, color: '#fc5b04', label: '156 screens & states delivered' },
      { width: 65,  color: '#4a9000', label: '90% bugs caught pre-production' },
      { width: 40,  color: '#464c63', label: '40% faster concept-to-release cycle' },
    ],
  },
  {
    title: 'Spotlight',
    description: 'AI-powered sports newsfeed. 60K users, D21 retention 70%.',
    imageSrc: '/works/Spotlight.png',
    layout: 'half' as const,
  },
  {
    title: 'Copy trade App',
    description: 'Conversion grew from 1.5% to 9.87%. MAU x3.',
    imageSrc: '/works/Copytrade.png',
    layout: 'half' as const,
  },
  {
    href: '/cases/livematch',
    title: 'Live Match Pages Redesign',
    description: 'SEO Top-3, reach +72%, x1.5 time on page.',
    imageSrc: '/works/sports-matches.png',
    layout: 'full' as const,
    statValue: 'Top 3',
    statLabel: 'SEO ranking',
    statRows: [
      { width: 65, color: '#fc5b04', label: '78% boost SEO' },
      { width: 52, color: '#4a9000', label: 'x1.5 time on page' },
      { width: 91, color: '#464c63', label: '3 sports redesigned' },
    ],
  },
];

---

<SidebarLayout title="Eugen Trapeznikov — Product Designer">

  <main id="home">

    <section class="hero">
      <div class="hero__top">
        <Avatar src="/Avatar.png" size="md" />
        <div class="hero__socials">
          <SocialButton href="https://linkedin.com/in/evgenii-trapeznikov/" type="linkedin" label="LinkedIn" />
          <SocialButton href="https://t.me/EvgeniiTrapeznikov" type="telegram" label="Telegram" />
          <SocialButton href="mailto:eugentrapeznikov@gmail.com" type="email" label="Email" />
          <SocialButton href="/cv.pdf" type="cv" label="Download CV" />
        </div>
      </div>
      <p class="hero__headline">
        I help teams make unclear ideas real — turning ideas into usable products based on people and data.
      </p>
      <div class="hero__actions">
        <a href="/cv.pdf" download class="btn-primary">Download CV</a>
      </div>
    </section>

    <section id="works" class="section">
      <div class="works">
        <WorkCard {...works[0]} />
        <div class="works__row">
          <WorkCard {...works[1]} />
          <WorkCard {...works[2]} />
        </div>
        <WorkCard {...works[3]} />
      </div>
    </section>

    <section id="initiatives" class="section">
      <h2 class="section-heading">Initiatives</h2>
      <div class="initiatives__row">
        <InitiativeCard caseStudy="RedCross" />
        <InitiativeCard caseStudy="ITMO" />
        <InitiativeCard caseStudy="WearSun" />
      </div>
    </section>

    <section id="contact" class="section">
      <h2 class="section-heading">Contacts</h2>
      <div class="contact-card">
        <span class="contact-eyebrow">Get in touch</span>
        <a href="mailto:eugentrapeznikov@gmail.com" class="contact-email">eugentrapeznikov@gmail.com</a>
        <div class="contact-links">
          <a href="https://linkedin.com/in/evgenii-trapeznikov/" target="_blank" rel="noopener" class="contact-link">LinkedIn</a>
          <a href="https://t.me/EvgeniiTrapeznikov" target="_blank" rel="noopener" class="contact-link">Telegram</a>
          <a href="/cv.pdf" download class="contact-link">Download CV</a>
        </div>
      </div>
    </section>

  </main>

</SidebarLayout>

<style>
  .hero { background: var(--bg-page); border-radius: var(--radius-xl); padding: 40px 64px 48px; display: flex; flex-direction: column; gap: 32px; }
  .hero__top { display: flex; gap: 24px; align-items: center; }
  .hero__socials { flex: 1; display: flex; gap: 12px; align-items: center; justify-content: flex-end; }
  .hero__headline { font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 44px; line-height: 1.35; color: var(--content-primary); }
  .hero__actions { display: flex; }

  .btn-primary {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 16px 32px; background: var(--content-primary); color: var(--bg-page);
    border-radius: var(--radius-full); font-family: 'Space Grotesk', sans-serif;
    font-weight: 500; font-size: 16px; border: none; cursor: pointer;
    transition: opacity 0.15s, transform 0.15s;
  }
  .btn-primary:hover { opacity: 0.85; transform: translateY(-1px); }

  main { display: flex; flex-direction: column; gap: 16px; }
  .section { display: flex; flex-direction: column; gap: 24px; }
  .section-heading { font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 44px; line-height: 1.35; color: var(--content-primary); }

  .works { display: flex; flex-direction: column; gap: 16px; }
  .works__row { display: flex; gap: 16px; }

  .initiatives__row { display: flex; gap: 16px; }

.contact-card {
    background: var(--bg-page); border-radius: var(--radius-xl); padding: 64px;
    display: flex; flex-direction: column; gap: 24px; min-height: 360px; justify-content: center;
}
  .contact-eyebrow { font-size: 11px; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: var(--content-secondary); }
  .contact-email { font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 32px; color: var(--content-primary); transition: color 0.15s; word-break: break-all; }
  .contact-email:hover { color: var(--accent-default); }
  .contact-links { display: flex; gap: 12px; flex-wrap: wrap; }
  .contact-link {
    display: inline-flex; align-items: center; padding: 12px 24px;
    background: var(--bg-elevated); border-radius: var(--radius-full);
    font-size: 14px; font-weight: 500; color: var(--content-primary);
    transition: background 0.15s, color 0.15s;
  }
  .contact-link:hover { background: var(--accent-default); color: var(--always-white); }

  @media (max-width: 960px) {
    .hero { padding: 28px 24px 36px; border-radius: var(--radius-lg); }
    .hero__headline { font-size: 28px; }
    .works__row { flex-direction: column; }
    .initiatives__row { flex-direction: column; }
    .section-heading { font-size: 32px; }
    .contact-card { padding: 32px 24px; }
    .contact-email { font-size: 22px; }
  }
  @media (max-width: 480px) {
    .hero__headline { font-size: 22px; }
    .hero__socials { gap: 8px; }
  }
</style>
